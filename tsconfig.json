{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "node",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "outDir": "./dist",
    "declaration": false,
    "jsx": "react",
    "lib": ["ES2020", "DOM"],
    "types": ["node"]
  },
  "include": ["main.ts"]
}
